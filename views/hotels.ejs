<!DOCTYPE html>
<html>

<head>
  <title>
    DAB Hotels
  </title>
  <link href="/stylesheets/hotels.css" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/base.css">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
  <%- include('./partials/loggedInAs.ejs', {username: username}) %>
  <%-include('./partials/navbar.ejs')%>
    <div class="container">
      <form method="GET" action="/hotels" class="mb-3">
        <input type="text" name="location" placeholder="Search by location" class="form-control"/>
        <button type="submit" class="btn btn-primary mt-2">Search</button>
      </form>
      <h2 class="p-3 text-center">Choose a hotel</h2>
      <hr>
      <div class="list-group">
        <% hotels.forEach(function(hotel) { %>
          <div class="row px-3 py-1 w-100">
            <span class="col py-1 bg-info me-1 rounded-1">
              <%=hotel.Name%><span class="right">
                  <%=hotel.Location%>
                </span>
            </span>
            <a href="/rooms/<%=hotel.id%>" class="col btn btn-success me-1"> Rent a room</a>
            <a href="/hotels/<%=hotel.id%>" class="col btn btn-warning me-1"> Details</a>
            <form action="/hotels/<%=hotel.id%>?_method=DELETE" method="POST" class="col">
              <button type="submit" class="btn btn-danger">Delete</button>
            </form>
          </div>
          <% }); %>
      </div>
    </div>
    <hr>
    <%-include('./partials/footer.ejs')%>
  <% if (username && username != 0) { %>
      <button name="addHotel" onclick="addHotel('http\:\/\/localhost:3000\/hotels' )"  class="btn btn-success"> Add a new hotel</button>
  <% } %>
  <script src="/javascripts/addHotel.js"></script>
</body>

</html>